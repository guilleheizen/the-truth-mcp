# Copialo a .env y poné tus valores reales. .env está en .gitignore.

# API key de Gemini. Sacala gratis en https://aistudio.google.com/apikey
# Aliases aceptados: GEMINI_API_KEY, GOOGLE_API_KEY, GEMINI_APIKEY, GOOGLE_GENAI_API_KEY
GEMINI_API_KEY=

# Path absoluto a la bóveda que el MCP gestiona.
# Alias aceptado: LLM_WIKI_PATH (back-compat)
VAULT_PATH=/Users/tu-usuario/Documents/my-vault

# Modelo de Gemini para el bibliotecario interno.
# - gemini-2.5-flash: rápido, barato, 1M context. Default y recomendado.
# - gemini-2.5-pro: mejor razonamiento, más caro.
# Podés pasar varios separados por coma para fijar fallbacks: "gemini-2.5-flash,gemini-2.5-pro"
GEMINI_MODEL=gemini-2.5-flash
