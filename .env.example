# Copialo a .env y poné tus valores reales. .env está en .gitignore.

# API key de Gemini. Sacala gratis en https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Path absoluto a la bóveda llm-wiki que el MCP gestiona.
LLM_WIKI_PATH=/Users/guilleheizen/Documents/gdg/llm-wiki

# Modelo de Gemini para el agente bibliotecario.
# - gemini-2.5-flash: rápido, barato, 1M context. Default y recomendado.
# - gemini-2.5-pro: mejor razonamiento, más caro.
GEMINI_MODEL=gemini-2.5-flash
