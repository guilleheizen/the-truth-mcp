{
  "mcpServers": {
    "the-truth": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/guilleheizen/the-truth-mcp",
        "the-truth-mcp"
      ],
      "env": {
        "VAULT_PATH": "__VAULT_PATH__",
        "GEMINI_API_KEY": "${GEMINI_API_KEY}",
        "GEMINI_MODEL": "gemini-2.5-flash"
      }
    }
  }
}
